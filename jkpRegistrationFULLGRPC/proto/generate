#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")"

# ── TypeScript (buf remote plugin) ──
buf generate

# ── Python (grpcio-tools — guarantees protobuf version compatibility) ──
PROTO_DIR="$(pwd)"
OUT_DIR="$(cd ../server/app/generated && pwd)"
rm -f "$OUT_DIR"/*_pb2*.py*
uv run --directory ../server python -m grpc_tools.protoc \
  -I "$PROTO_DIR" \
  --python_out="$OUT_DIR" \
  --grpc_python_out="$OUT_DIR" \
  --pyi_out="$OUT_DIR" \
  "$PROTO_DIR"/*.proto

# Fix Python gRPC imports (import X_pb2 → from app.generated import X_pb2)
sed -i 's/^import \(.*_pb2\)/from app.generated import \1/' ../server/app/generated/*_pb2_grpc.py

echo "✓ Generated Python + TypeScript from proto/"
