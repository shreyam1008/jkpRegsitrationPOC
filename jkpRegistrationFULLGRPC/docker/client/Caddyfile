# ============================================================
# Caddy — TLS, static files, reverse proxy, HTTP/3
# ============================================================
#
# Architecture (no nginx — Caddy serves static files directly):
#   registrationpoc.shreyam1008.com.np     →  /srv (built React SPA)
#   registrationpocapi.shreyam1008.com.np  →  server:8080 (grpc-web proxy)
#
# TLS mode:
#   Default uses Caddy's internal CA (self-signed). Works immediately
#   on LAN with zero config. Browsers will show a warning unless you
#   install Caddy's root CA on devices.
#
#   To switch to Let's Encrypt (requires DNS challenge on LAN):
#   1. Remove "tls internal" from both site blocks
#   2. Uncomment the global acme_dns block below
#   3. Set CLOUDFLARE_API_TOKEN env var (or your DNS provider)
#
# Domains:
#   On LAN/VPN: point both domains to the server's LAN IP (local DNS or /etc/hosts).
#   On Internet: Cloudflare Tunnel handles routing (see docker-compose.yml).
# ============================================================

{
	# Admin API off in production
	admin off

	# Uncomment for Let's Encrypt via DNS challenge:
	# email admin@shreyam1008.com.np
	# acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

# ─── Shared snippet: security headers ────────────────────────
(security_headers) {
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://registrationpocapi.shreyam1008.com.np"
		# Hide server identity
		-Server
		-X-Powered-By
	}
}

# ─── Shared snippet: frontend (SPA) ──────────────────────────
(frontend) {
	encode zstd gzip

	import security_headers

	root * /srv

	# Cache hashed assets forever (Vite adds content hash to filenames)
	@assets path_regexp \.(?:js|css|woff2?|ttf|eot|ico|svg|png|jpg|jpeg|gif|webp)$
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# SPA fallback — serve index.html for all non-file routes
	try_files {path} /index.html
	file_server
}

# ─── Shared snippet: backend API (grpc-web proxy) ────────────
(backend) {
	encode zstd gzip

	import security_headers

	reverse_proxy server:8080 {
		transport http {
			keepalive             30s
			keepalive_idle_conns  100
			read_timeout          30s
			write_timeout         30s
		}

		health_uri      /healthz
		health_interval 10s
		health_timeout  3s

		# Buffer responses to free up the proxy faster
		flush_interval -1
	}

	# Limit request body size (16 MB)
	request_body {
		max_size 16MB
	}
}

# ─── HTTPS (LAN / VPN — self-signed cert, direct access) ─────
reg.jkp.com {
	tls internal
	import frontend
}

regapi.jkp.com {
	tls internal
	import backend
}

# ─── HTTP (Cloudflare Tunnel — no TLS needed internally) ─────
http://registrationpoc.shreyam1008.com.np {
	import frontend
}

http://registrationpocapi.shreyam1008.com.np {
	import backend
}
